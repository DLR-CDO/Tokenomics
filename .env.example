# ── Postgres ──────────────────────────────────────────────
DATABASE_URL=postgres://dashboard:dashboard@localhost:5433/token_dashboard

# ── Cursor ────────────────────────────────────────────────
# Enterprise Admin API (read-only key from team settings)
CURSOR_ADMIN_API_KEY=

# Optional: override default Cursor API base URL
# CURSOR_API_BASE_URL=https://api.cursor.com

# How far back to pull daily usage + filtered usage events (chunked in ≤30d API windows). Max 3650.
CURSOR_SYNC_LOOKBACK_DAYS=730

# Optional: force analytics window (e.g. 365d). If unset, sync tries 365d → 180d → 90d → 30d.
# CURSOR_ANALYTICS_LOOKBACK=365d

# ── OpenAI ────────────────────────────────────────────────
# Org admin key from Settings > Admin keys
OPENAI_ADMIN_API_KEY=
OPENAI_ORG_ID=

# How far back to pull OpenAI usage + cost data (daily buckets). Max 180.
OPENAI_SYNC_LOOKBACK_DAYS=90

# ── Azure AI ──────────────────────────────────────────────
# JSON array describing Azure resources to monitor.
# Each object: { "subscriptionId": "...", "resourceGroup": "...", "accountName": "..." }
# AZURE_RESOURCES=[{"subscriptionId":"<sub-id>","resourceGroup":"<rg>","accountName":"<account>"}]

# How far back to pull Azure metrics on first sync (days). Default 90.
# AZURE_SYNC_LOOKBACK_DAYS=90

# NOTE: Azure sync authenticates via the Azure CLI (`az login`), not an API key.

# ── Security ──────────────────────────────────────────────
# Shared secret to protect /api/sync/* endpoints when called by a cron scheduler.
# CRON_SECRET=
